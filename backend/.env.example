# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/steganography_db?retryWrites=true&w=majority

# JWT Configuration
SECRET_KEY=your_super_secret_key_change_this_in_production_use_secrets_module
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email Configuration (Gmail SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_specific_password

# Face Recognition Threshold (0.0-1.0, lower = stricter matching)
FACE_RECOGNITION_THRESHOLD=0.6

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
